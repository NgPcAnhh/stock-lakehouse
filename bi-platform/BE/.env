# ============================================
# Database
# ============================================
DATABASE_URL=postgresql+psycopg2://admin:123456@localhost:5432/postgres
DATABASE_URL_SYNC=postgresql://admin:123456@localhost:5432/postgres

# ============================================
# Redis
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# ============================================
# App
# ============================================
APP_NAME=Stock Market API
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# External APIs
# ============================================
SSI_IBOARD_BASE_URL=https://iboard-query.ssi.com.vn/v2
SIMPLIZE_WS_URL=wss://stream2.simplize.vn/ws

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# Server
# ============================================
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ============================================
# Stock MV refresh scheduler
# ============================================
STOCK_MV_REFRESH_ENABLED=true
STOCK_MV_REFRESH_INTERVAL_SECONDS=3600
STOCK_MV_REFRESH_RUN_ON_STARTUP=true

# ============================================
# Auth / JWT
# ============================================
JWT_SECRET_KEY=super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# Google OAuth 2.0
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ============================================
# Email (SMTP) - cho reset password
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@stockanalysis.vn

# ============================================
# Embedding Model Settings
# ============================================
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1024

# ============================================
# OpenAI (LLM for Chatbot)
# ============================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_FINETUNED_MODEL=

