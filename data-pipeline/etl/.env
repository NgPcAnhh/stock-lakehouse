# ====== AIRFLOW ======
AIRFLOW_UID=50000
AIRFLOW_IMAGE_NAME=apache/airflow:2.9.3
AIRFLOW_PROJ_DIR=./airflow
_PIP_ADDITIONAL_REQUIREMENTS=
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# ====== KAFKA ======
# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_INTERNAL_BOOTSTRAP_SERVERS=kafka:9093

# Topics Configuration
TOPIC_STOCK_QUOTES=market.quotes.raw
TOPIC_STOCK_CANDLES=stock-candles
TOPIC_PARTITIONS=3
TOPIC_REPLICATION_FACTOR=1

# MinIO Configuration
# Set MINIO_ENDPOINT=http://localhost:9000 for local testing, http://minio:9000 for Docker (automatically overridden in docker-compose.yaml)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=thongtin-congty-va-bctc

# Producer Configuration
PRODUCER_BATCH_SIZE=16384
PRODUCER_LINGER_MS=10
PRODUCER_COMPRESSION_TYPE=snappy
PRODUCER_MAX_IN_FLIGHT_REQUESTS=5

# Consumer Configuration
CONSUMER_GROUP_ID=stock-data-consumer-group
CONSUMER_AUTO_OFFSET_RESET=earliest
CONSUMER_ENABLE_AUTO_COMMIT=true
CONSUMER_MAX_POLL_RECORDS=500

# Database Configuration (for consumer)
# Set DB_HOST=localhost for local testing, dwh-postgres for Docker deployment
DB_HOST=dwh-postgres
DB_DSN=postgresql://admin:123456@dwh-postgres:5432/postgres
DB_SCHEMA=hethong_phantich_chungkhoan

# WebSocket Configuration
WEBSOCKET_URL=wss://stream2.simplize.vn/ws
SYMBOL_LIMIT=2000
SUB_BATCH_SIZE=500
